{
  "name": "backend",
  "version": "1.0.0",
  "description": "Neosix Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "seed:admin": "node src/scripts/seedAdmin.js",
    "seed:all": "node src/seeds/index.js",
    "test:models": "node src/tests/validateModels.js",
    "lint": "eslint src --ext .js",
    "format": "prettier --write \"src/**/*.js\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@neosix/shared": "*",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.0.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.20.0",
    "mongoose": "^8.2.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "pino": "^9.14.0",
    "pino-pretty": "^11.0.0",
    "slugify": "^1.6.6",
    "winston": "^3.11.0"
  }
